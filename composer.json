{
    "name": "vodeco/mayar-payment-gateway",
    "description": "Mayar Payment Gateway for WooCommerce — Virtual Account, QRIS, E-Wallet, Kartu Kredit/Debit",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Wahyu (Vodeco Media Group)",
            "email": "ademaswahyubusiness@gmail.com",
            "homepage": "https://ademaswahyu.my.id/"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "scripts": {
        "build-zip": [
            "@php build/build.php"
        ],
        "bump": [
            "@php build/bump.php"
        ],
        "test": [
            "phpunit tests/"
        ]
    },
    "scripts-descriptions": {
        "build-zip": "Generate production-ready zip file (exclude dev files)",
        "bump": "Bump version: composer bump <major|minor|patch> (default: patch)",
        "test": "Jalankan PHPUnit test suite"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
